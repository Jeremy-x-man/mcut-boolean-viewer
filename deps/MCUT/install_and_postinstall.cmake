# install_and_postinstall.cmake
# Called by ExternalProject INSTALL_COMMAND for dep_MCUT.
#
# MCUT's cmake_install.cmake only installs headers and text files.
# The static library (libmcut.a / mcut.lib) is NOT installed by cmake install
# because the COMPONENT-based install rule for "static_libraries" is missing
# from the generated cmake_install.cmake in MCUT 1.3.0.
#
# Workaround (same approach used by many projects for non-standard deps):
#   1. Run cmake install for headers + text_files
#   2. Manually copy libmcut.a from the build directory to lib/
#   3. Generate a proper mcut-config.cmake for find_package(mcut)
#
# Required variables (passed via -D from ExternalProject INSTALL_COMMAND):
#   BINARY_DIR      — ExternalProject binary directory (<BINARY_DIR>)
#   DESTDIR         — install prefix
#   CMAKE_COMMAND   — path to cmake executable

if(NOT DEFINED BINARY_DIR)
    message(FATAL_ERROR "BINARY_DIR not set")
endif()
if(NOT DEFINED DESTDIR)
    message(FATAL_ERROR "DESTDIR not set")
endif()
if(NOT DEFINED CMAKE_COMMAND)
    set(CMAKE_COMMAND cmake)
endif()

# ---- Step 1: Install headers and text files --------------------------------
message(STATUS "MCUT install: headers + text_files")
execute_process(
    COMMAND "${CMAKE_COMMAND}" --install "${BINARY_DIR}"
            --config Release
            --prefix "${DESTDIR}"
    RESULT_VARIABLE _result
    OUTPUT_VARIABLE _out
    ERROR_VARIABLE  _err
)
if(NOT _result EQUAL 0)
    message(FATAL_ERROR "MCUT cmake install failed:\n${_err}")
endif()
message(STATUS "  → ${_out}")

# ---- Step 2: Copy libmcut.a from build dir to install/lib/ ----------------
# MCUT 1.3.0 does not install the static library via cmake install.
# We copy it directly from the build output directory.
set(_lib_dest_dir "${DESTDIR}/lib")
file(MAKE_DIRECTORY "${_lib_dest_dir}")

# Possible library names and locations in the build tree
set(_found_lib "")
foreach(_candidate
    "${BINARY_DIR}/lib/libmcut.a"
    "${BINARY_DIR}/lib/static/libmcut.a"
    "${BINARY_DIR}/libmcut.a"
    "${BINARY_DIR}/lib/Release/mcut.lib"
    "${BINARY_DIR}/Release/mcut.lib"
    "${BINARY_DIR}/lib/mcut.lib"
    "${BINARY_DIR}/lib/static/mcut.lib"
    "${BINARY_DIR}/mcut.lib"
)
    if(EXISTS "${_candidate}")
        set(_found_lib "${_candidate}")
        break()
    endif()
endforeach()

if(_found_lib STREQUAL "")
    message(FATAL_ERROR
        "MCUT static library not found in build directory: ${BINARY_DIR}\n"
        "Searched: lib/libmcut.a, lib/static/libmcut.a, Release/mcut.lib, ...")
endif()

get_filename_component(_lib_name "${_found_lib}" NAME)
set(_lib_dst "${_lib_dest_dir}/${_lib_name}")

message(STATUS "MCUT post-install: copying ${_found_lib} → ${_lib_dst}")
file(COPY "${_found_lib}" DESTINATION "${_lib_dest_dir}")

# ---- Step 3: Generate cmake package config --------------------------------
set(_cmake_dir "${DESTDIR}/lib/cmake/mcut")
file(MAKE_DIRECTORY "${_cmake_dir}")

# Write mcut-targets.cmake with absolute paths
file(WRITE "${_cmake_dir}/mcut-targets.cmake"
"# Generated by mcut-boolean-viewer deps/MCUT/install_and_postinstall.cmake
if(NOT TARGET mcut::mcut)
    add_library(mcut::mcut STATIC IMPORTED)
    set_target_properties(mcut::mcut PROPERTIES
        IMPORTED_LOCATION \"${_lib_dst}\"
        INTERFACE_INCLUDE_DIRECTORIES \"${DESTDIR}/include\"
    )
    if(NOT WIN32)
        find_package(Threads QUIET)
        if(Threads_FOUND)
            set_property(TARGET mcut::mcut APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES Threads::Threads)
        endif()
    endif()
endif()
")

# Write mcut-config.cmake
file(WRITE "${_cmake_dir}/mcut-config.cmake"
"# mcut-config.cmake — generated by mcut-boolean-viewer deps build
include(\"\${CMAKE_CURRENT_LIST_DIR}/mcut-targets.cmake\")
")

message(STATUS "MCUT post-install complete:")
message(STATUS "  Library : ${_lib_dst}")
message(STATUS "  Headers : ${DESTDIR}/include/mcut/")
message(STATUS "  CMake   : ${_cmake_dir}/mcut-config.cmake")
