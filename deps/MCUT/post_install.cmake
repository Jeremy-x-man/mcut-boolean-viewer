# post_install.cmake — run after MCUT ExternalProject install step
# Normalizes MCUT's non-standard install layout:
#   lib/static/libmcut.a  →  lib/libmcut.a
# Then generates a proper CMake package config so find_package(mcut) works.
#
# Called via:
#   cmake -DDESTDIR=<path> -P post_install.cmake

if(NOT DEFINED DESTDIR)
    message(FATAL_ERROR "DESTDIR must be defined")
endif()

# ---- 1. Normalize library path ----------------------------------------
set(_src_static "${DESTDIR}/lib/static/libmcut.a")
set(_src_shared "${DESTDIR}/lib/shared/libmcut.so")
set(_dst_lib    "${DESTDIR}/lib/libmcut.a")

if(EXISTS "${_src_static}" AND NOT EXISTS "${_dst_lib}")
    message(STATUS "MCUT post-install: moving ${_src_static} → ${_dst_lib}")
    file(COPY "${_src_static}" DESTINATION "${DESTDIR}/lib")
endif()

# Windows MSVC layout: lib/static/mcut.lib
set(_src_win "${DESTDIR}/lib/static/mcut.lib")
set(_dst_win "${DESTDIR}/lib/mcut.lib")
if(EXISTS "${_src_win}" AND NOT EXISTS "${_dst_win}")
    message(STATUS "MCUT post-install: moving ${_src_win} → ${_dst_win}")
    file(COPY "${_src_win}" DESTINATION "${DESTDIR}/lib")
endif()

# ---- 2. Generate cmake package config ----------------------------------
set(_cmake_dir "${DESTDIR}/lib/cmake/mcut")
file(MAKE_DIRECTORY "${_cmake_dir}")

# Determine the actual library file name
if(EXISTS "${DESTDIR}/lib/libmcut.a")
    set(_lib_file "${DESTDIR}/lib/libmcut.a")
elseif(EXISTS "${DESTDIR}/lib/mcut.lib")
    set(_lib_file "${DESTDIR}/lib/mcut.lib")
else()
    message(WARNING "MCUT library not found in ${DESTDIR}/lib — skipping cmake config generation")
    return()
endif()

# Write mcut-targets.cmake
file(WRITE "${_cmake_dir}/mcut-targets.cmake"
"# Generated by mcut-boolean-viewer deps post_install.cmake
if(NOT TARGET mcut::mcut)
    add_library(mcut::mcut STATIC IMPORTED)
    set_target_properties(mcut::mcut PROPERTIES
        IMPORTED_LOCATION \"${_lib_file}\"
        INTERFACE_INCLUDE_DIRECTORIES \"${DESTDIR}/include\"
    )
    if(NOT WIN32)
        find_package(Threads QUIET)
        if(Threads_FOUND)
            set_property(TARGET mcut::mcut APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES Threads::Threads)
        endif()
    endif()
endif()
")

# Write mcut-config.cmake
file(WRITE "${_cmake_dir}/mcut-config.cmake"
"# mcut-config.cmake — generated by mcut-boolean-viewer deps build
include(\"\${CMAKE_CURRENT_LIST_DIR}/mcut-targets.cmake\")
")

message(STATUS "MCUT post-install: cmake package config written to ${_cmake_dir}")
